# ============================================
# FRONTEND ENVIRONMENT (.env in /frontend)
# ============================================

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Environment
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# Application Settings
REACT_APP_APP_NAME=Impactly
REACT_APP_LOGO_URL=https://example.com/logo.png

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# Optional: Google Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Optional: Sentry Error Tracking
REACT_APP_SENTRY_DSN=https://your-key@sentry.io/project-id

# Optional: Map Integration (for location features)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe Public Key (for payments - future)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_key

# Session/Token
REACT_APP_TOKEN_STORAGE_KEY=impactly_token
REACT_APP_USER_ROLE_KEY=userRole

# Logging
REACT_APP_LOG_LEVEL=debug
